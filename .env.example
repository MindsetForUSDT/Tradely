# ============================================
# TradeumDiary — Конфигурация окружения
# Скопируй этот файл в .env и заполни значения
# ============================================

# --- Supabase ---
# Project URL (публичный, доступен на клиенте)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
# Anon Key (публичный, только для RLS-ограниченных запросов)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- НИКОГДА НЕ ИСПОЛЬЗУЙ ЭТОТ КЛЮЧ НА КЛИЕНТЕ ---
# Service Role Key (используется ТОЛЬКО в Edge Functions и Cron Jobs)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Платежная система (YooKassa) ---
# ID магазина
YOOKASSA_SHOP_ID=your_shop_id
# Секретный ключ (используется ТОЛЬКО на бэкенде)
YOOKASSA_SECRET_KEY=test_sk_...

# --- Cron Job Secret ---
# Секретный токен для защиты Cron Job endpoint'ов
CRON_SECRET=your_random_secret_here

# --- App ---
APP_URL=https://tradeumdiary.ru